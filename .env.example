DJANGO_SECRET_KEY=replace-this-with-a-long-random-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-site.onrender.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-site.onrender.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DATABASE_URL=postgresql://user:password@host:5432/database
REGISTRATION_ACCESS_PASSWORD=change-this-registration-password
